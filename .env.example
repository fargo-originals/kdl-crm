# Supabase REST URL (used by the app)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# Supabase direct Postgres URL (used by Drizzle migrations only)
# Project Settings → Database → Connection string → URI (direct connection, NOT pooler)
DATABASE_URL=postgresql://postgres.XXXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth (JWT)
JWT_SECRET=your-super-secret-key-min-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OWNER_EMAIL=admin@kentodevlab.com
OWNER_PASSWORD=changeme123

# Landing integration
LANDING_REVALIDATE_SECRET=
NEXT_PUBLIC_LANDING_URL=https://kentodevlab.com

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Email
RESEND_FROM_EMAIL=hola@kentodevlab.com
RESEND_API_KEY=your-resend-api-key

# AI agent
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
